{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "server": "nodemon server.js",
    "start": "node server.js",
    "test": "jest --config config/jest.config.cjs",
    "test:unit": "jest --config config/jest.config.cjs tests/unit",
    "test:integration": "jest --config config/jest.config.cjs tests/integration",
    "test:all": "npm run test:unit && npm run test:integration",
    "test:watch": "jest --config config/jest.config.cjs --watch",
    "test:unit:watch": "jest --config config/jest.config.cjs tests/unit --watch",
    "test:integration:watch": "jest --config config/jest.config.cjs tests/integration --watch",
    "test:coverage": "jest --config config/jest.config.cjs --coverage",
    "test:unit:coverage": "jest --config config/jest.config.cjs tests/unit --coverage",
    "test:integration:coverage": "jest --config config/jest.config.cjs tests/integration --coverage",
    "test:performance": "npm run perf:smoke",
    "perf:smoke": "artillery run tests/performance/smoke.yml",
    "perf:load": "artillery run tests/performance/load.yml",
    "perf:stress": "artillery run tests/performance/stress.yml",
    "perf:report:load": "artillery run tests/performance/load.yml --output tests/performance/results/load-report.json && artillery report tests/performance/results/load-report.json --output tests/performance/results/load-report.html"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "google-auth-library": "^9.15.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.1.6",
    "multer": "^2.0.2",
    "openai": "^6.21.0",
    "pdfkit": "^0.17.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "artillery": "^2.0.30",
    "babel-jest": "^30.2.0",
    "jest": "^30.2.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2"
  }
}
